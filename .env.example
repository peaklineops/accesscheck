# Copy to .env.local and fill in values

# Claude API key (from Anthropic Console)
ANTHROPIC_API_KEY=

# Stripe (for paid report tier)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Your deployed app URL (no trailing slash) — used in Stripe success/cancel URLs
NEXT_PUBLIC_APP_URL=https://accesscheck.app

# Vercel KV (optional — for persisting reports server-side)
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=
